import java.awt.*;
import java.awt.geom.*;
import javax.swing.*;

public class TicTacToe extends JFrame {
    private int[] board = new int[9]; // 0 = Empty, 1 = Human (Circle), 2 = AI (Square)
    private final int EMPTY = 0, HUMAN = 1, AI = 2;
    private boolean humanTurn = true;
    private String gameStatus = "YOUR TURN";
    private String aiDecisionText = "Awaiting move...";

    private final Color BG_COLOR = Color.decode("#05070B");
    private final Color PANEL_BG = Color.decode("#0E161F");
    private final Color ACCENT_CYAN = Color.decode("#14B8A6");
    private final Color TEXT_WHITE = Color.decode("#E2E8F0");
    private final Color TEXT_MUTED = Color.decode("#64748B");

    private BoardPanel boardPanel;
    private JLabel statusValueLabel, decisionValueLabel;

    public TicTacToe() {
        setTitle("Tic-Tac-Toe Challenge");
        setSize(850, 580);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        getContentPane().setBackground(BG_COLOR);
        setLayout(new BorderLayout());

        JPanel headerPanel = new JPanel(new BorderLayout());
        headerPanel.setBackground(BG_COLOR);
        headerPanel.setBorder(BorderFactory.createEmptyBorder(25, 40, 10, 40));

        JLabel titleLabel = new JLabel("TIC-TAC-TOE: MINIMAX CHALLENGE", JLabel.LEFT);
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        titleLabel.setForeground(ACCENT_CYAN);
        headerPanel.add(titleLabel, BorderLayout.WEST);

        JPanel legendPanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setFont(new Font("Segoe UI", Font.BOLD, 12));
                g2.setColor(TEXT_WHITE);
                g2.drawString("HUMAN:", 5, 22);
                drawTotem(g2, 60, 5, 24, 1);
                g2.setColor(TEXT_WHITE);
                g2.drawString("AI:", 95, 22);
                drawTotem(g2, 120, 5, 24, 2);
            }
        };
        legendPanel.setPreferredSize(new Dimension(160, 35));
        legendPanel.setBackground(BG_COLOR);
        headerPanel.add(legendPanel, BorderLayout.EAST);
        add(headerPanel, BorderLayout.NORTH);

        JPanel mainWorkspace = new JPanel(new GridBagLayout());
        mainWorkspace.setBackground(BG_COLOR);
        GridBagConstraints gbc = new GridBagConstraints();

        boardPanel = new BoardPanel();
        gbc.gridx = 0; gbc.gridy = 0;
        gbc.weightx = 0.6; gbc.weighty = 1.0;
        gbc.fill = GridBagConstraints.BOTH;
        gbc.insets = new Insets(10, 40, 20, 20);
        mainWorkspace.add(boardPanel, gbc);

        JPanel sidebarContainer = new JPanel();
        sidebarContainer.setLayout(new BoxLayout(sidebarContainer, BoxLayout.Y_AXIS));
        sidebarContainer.setBackground(BG_COLOR);
        sidebarContainer.setPreferredSize(new Dimension(320, 400));

        JPanel statusModule = createDashboardBox("STATUS MONITOR", statusValueLabel = new JLabel("GAME ACTIVE"));
        statusValueLabel.setForeground(ACCENT_CYAN);
        sidebarContainer.add(statusModule);
        sidebarContainer.add(Box.createVerticalStrut(20));

        JPanel aiModule = createDashboardBox("MINIMAX ALGORITHM ENGINE", decisionValueLabel = new JLabel("<html>Engine Idle.<br>Waiting for Human Move.</html>"));
        sidebarContainer.add(aiModule);
        sidebarContainer.add(Box.createVerticalStrut(35));

        JButton resetBtn = new JButton("RESET SYSTEM MATRIX");
        resetBtn.setFont(new Font("Segoe UI", Font.BOLD, 13));
        resetBtn.setBackground(PANEL_BG);
        resetBtn.setForeground(TEXT_WHITE);
        resetBtn.setFocusPainted(false);
        resetBtn.setBorder(BorderFactory.createLineBorder(Color.decode("#334155"), 1));
        resetBtn.setPreferredSize(new Dimension(300, 45));
        resetBtn.setMaximumSize(new Dimension(300, 45));
        resetBtn.addActionListener(e -> resetGame());
        sidebarContainer.add(resetBtn);

        gbc.gridx = 1; gbc.gridy = 0;
        gbc.weightx = 0.4; gbc.weighty = 1.0;
        gbc.insets = new Insets(10, 10, 20, 40);
        mainWorkspace.add(sidebarContainer, gbc);

        add(mainWorkspace, BorderLayout.CENTER);
        setVisible(true);
    }

    private JPanel createDashboardBox(String panelTitle, JLabel diagnosticContent) {
        JPanel box = new JPanel();
        box.setLayout(new BorderLayout());
        box.setBackground(PANEL_BG);
        box.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(Color.decode("#1E293B"), 1),
                BorderFactory.createEmptyBorder(15, 20, 15, 20)
        ));
        box.setMaximumSize(new Dimension(300, 110));
        box.setPreferredSize(new Dimension(300, 110));

        JLabel title = new JLabel(panelTitle);
        title.setFont(new Font("Segoe UI", Font.BOLD, 12));
        title.setForeground(TEXT_MUTED);
        box.add(title, BorderLayout.NORTH);

        diagnosticContent.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        diagnosticContent.setForeground(TEXT_WHITE);
        box.add(diagnosticContent, BorderLayout.CENTER);

        return box;
    }

    private void cellClicked(int idx) {
        if (board[idx] == EMPTY && humanTurn && !checkWinnerExists()) {
            board[idx] = HUMAN;
            humanTurn = false;
            updateGameMonitor();
            boardPanel.repaint();

            if (!checkWinnerExists()) {
                Timer timer = new Timer(450, e -> triggerAIMove());
                timer.setRepeats(false);
                timer.start();
            }
        }
    }

    private void triggerAIMove() {
        int bestScore = Integer.MIN_VALUE;
        int targetMove = -1;

        for (int i = 0; i < 9; i++) {
            if (board[i] == EMPTY) {
                board[i] = AI;
                int score = minimax(board, 0, false);
                board[i] = EMPTY;
                if (score > bestScore) {
                    bestScore = score;
                    targetMove = i;
                }
            }
        }

        if (targetMove != -1) {
            board[targetMove] = AI;
            aiDecisionText = "<html>AI selected slot index " + targetMove + "<br>Calculated Max weight value.</html>";
        }

        humanTurn = true;
        updateGameMonitor();
        boardPanel.repaint();
    }

    private int minimax(int[] tempBoard, int depth, boolean isMax) {
        int eval = evaluateState(tempBoard);
        if (eval == 10) return eval - depth;
        if (eval == -10) return eval + depth;
        if (!hasMovesLeft(tempBoard)) return 0;

        if (isMax) {
            int best = Integer.MIN_VALUE;
            for (int i = 0; i < 9; i++) {
                if (tempBoard[i] == EMPTY) {
                    tempBoard[i] = AI;
                    best = Math.max(best, minimax(tempBoard, depth + 1, false));
                    tempBoard[i] = EMPTY;
                }
            }
            return best;
        } else {
            int best = Integer.MAX_VALUE;
            for (int i = 0; i < 9; i++) {
                if (tempBoard[i] == EMPTY) {
                    tempBoard[i] = HUMAN;
                    best = Math.min(best, minimax(tempBoard, depth + 1, true));
                    tempBoard[i] = EMPTY;
                }
            }
            return best;
        }
    }

    private boolean checkWinnerExists() {
        int winState = evaluateState(board);
        return (winState != 0) || !hasMovesLeft(board);
    }

    private int evaluateState(int[] b) {
        int[][] lines = {{0,1,2},{3,4,5},{6,7,8},{0,3,6},{1,4,7},{2,5,8},{0,4,8},{2,4,6}};
        for (int[] l : lines) {
            if (b[l[0]] != EMPTY && b[l[0]] == b[l[1]] && b[l[0]] == b[l[2]]) {
                return (b[l[0]] == AI) ? 10 : -10;
            }
        }
        return 0;
    }

    private boolean hasMovesLeft(int[] b) {
        for (int v : b) if (v == EMPTY) return true;
        return false;
    }

    private void updateGameMonitor() {
        int state = evaluateState(board);
        if (state == -10) {
            statusValueLabel.setText("HUMAN PLAYER WINS!");
            statusValueLabel.setForeground(ACCENT_CYAN);
        } else if (state == 10) {
            statusValueLabel.setText("SYSTEM OVERLORD WINS!");
            statusValueLabel.setForeground(Color.decode("#F43F5E"));
        } else if (!hasMovesLeft(board)) {
            statusValueLabel.setText("STALEMATE // DRAW GAME");
            statusValueLabel.setForeground(TEXT_MUTED);
        } else {
            statusValueLabel.setText(humanTurn ? "YOUR MOVE" : "AI COMPUTING...");
            statusValueLabel.setForeground(humanTurn ? ACCENT_CYAN : Color.decode("#E67E22"));
        }
        decisionValueLabel.setText(aiDecisionText);
    }

    private void resetGame() {
        board = new int[9];
        humanTurn = true;
        aiDecisionText = "Engine Resetted. Awaiting initialization.";
        updateGameMonitor();
        boardPanel.repaint();
    }

    private static void drawTotem(Graphics2D g2, int x, int y, int size, int type) {
        if (type == 0) return;

        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        double scale = size / 100.0;
        AffineTransform oldXform = g2.getTransform();
        g2.translate(x, y);
        g2.scale(scale, scale);

        if (type == 1) { // Type 1: Green Circle Totem
            Color greenBase = Color.decode("#529B82");
            Color greenAccent = Color.decode("#C19C45");

            g2.setColor(greenBase);
            g2.fill(new Ellipse2D.Double(2, 2, 96, 96));
            g2.setColor(Color.BLACK);
            g2.setStroke(new BasicStroke(4f));
            g2.draw(new Ellipse2D.Double(2, 2, 96, 96));

            g2.setColor(greenAccent);
            g2.fill(new Arc2D.Double(2, 22, 30, 56, 90, 180, Arc2D.CHORD));
            g2.fill(new Arc2D.Double(68, 22, 30, 56, 270, 180, Arc2D.CHORD));

            g2.setColor(Color.BLACK);
            g2.draw(new Arc2D.Double(2, 22, 30, 56, 90, 180, Arc2D.CHORD));
            g2.draw(new Arc2D.Double(68, 22, 30, 56, 270, 180, Arc2D.CHORD));
            g2.draw(new Line2D.Double(50, 2, 50, 98));
            g2.draw(new Arc2D.Double(15, 2, 70, 50, 180, 180, Arc2D.OPEN));

            g2.setStroke(new BasicStroke(5f, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
            g2.draw(new Line2D.Double(28, 32, 42, 32));
            g2.draw(new Line2D.Double(58, 32, 72, 32));
            g2.draw(new Line2D.Double(44, 45, 50, 55));
            g2.draw(new Line2D.Double(56, 45, 50, 55));

        } else if (type == 2) { // Type 2: Gold Square Totem
            Color goldBase = Color.decode("#D2A454");
            Color orangeAccent = Color.decode("#C85B28");

            g2.setColor(goldBase);
            g2.fill(new Rectangle2D.Double(2, 2, 96, 96));
            g2.setColor(Color.BLACK);
            g2.setStroke(new BasicStroke(4f));
            g2.draw(new Rectangle2D.Double(2, 2, 96, 96));

            g2.setColor(orangeAccent);
            g2.fill(new Ellipse2D.Double(36, 32, 28, 28));
            g2.setColor(Color.BLACK);
            g2.draw(new Ellipse2D.Double(36, 32, 28, 28));

            int[] xPointsL = {2, 28, 28, 2};
            int[] yPointsL = {65, 52, 98, 98};
            g2.setColor(orangeAccent);
            g2.fillPolygon(xPointsL, yPointsL, 4);
            g2.setColor(Color.BLACK);
            g2.drawPolygon(xPointsL, yPointsL, 4);

            int[] xPointsR = {98, 72, 72, 98};
            int[] yPointsR = {65, 52, 98, 98};
            g2.setColor(orangeAccent);
            g2.fillPolygon(xPointsR, yPointsR, 4);
            g2.setColor(Color.BLACK);
            g2.drawPolygon(xPointsR, yPointsR, 4);

            g2.setStroke(new BasicStroke(4f));
            g2.draw(new Ellipse2D.Double(20, 12, 16, 16));
            g2.draw(new Ellipse2D.Double(64, 12, 16, 16));
            g2.draw(new Line2D.Double(16, 20, 32, 20));
            g2.draw(new Line2D.Double(68, 20, 84, 20));

            g2.draw(new Rectangle2D.Double(32, 68, 36, 14));
            g2.draw(new Line2D.Double(32, 75, 68, 75));
        }

        g2.setTransform(oldXform);
    }

    private class BoardPanel extends JPanel {
        public BoardPanel() {
            setBackground(BG_COLOR);
            addMouseListener(new java.awt.event.MouseAdapter() {
                @Override
                public void mousePressed(java.awt.event.MouseEvent e) {
                    int cellW = getWidth() / 3;
                    int cellH = getHeight() / 3;
                    int col = e.getX() / cellW;
                    int row = e.getY() / cellH;
                    if (col >= 0 && col < 3 && row >= 0 && row < 3) {
                        cellClicked(row * 3 + col);
                    }
                }
            });
        }

        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g;
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

            int w = getWidth();
            int h = getHeight();
            int cellW = w / 3;
            int cellH = h / 3;

            g2.setColor(PANEL_BG);
            for (int r = 0; r < 3; r++) {
                for (int c = 0; c < 3; c++) {
                    g2.fill(new Rectangle2D.Double(c * cellW + 6, r * cellH + 6, cellW - 12, cellH - 12));
                }
            }

            int totemSize = Math.min(cellW, cellH) - 40;
            for (int i = 0; i < 9; i++) {
                int r = i / 3;
                int c = i % 3;
                int xOffset = c * cellW + (cellW - totemSize) / 2;
                int yOffset = r * cellH + (cellH - totemSize) / 2;
                drawTotem(g2, xOffset, yOffset, totemSize, board[i]);
            }
        }
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(TicTacToe::new);
    }
}
